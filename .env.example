# ─── MediTrack Environment Variables ───────────────────────────────────────
# Copy this file to .env.local and fill in your values

# Anthropic API Key (for MediBot AI chat + Health Reports AI analysis)
# Get yours at: https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Firebase Config (already pre-filled from your exported project) ─────────
# These are already bundled in src/lib/firebase.ts from your export.
# Override here ONLY if you want to use a different Firebase project.

# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_FIRESTORE_DB=
